{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.jean.desktop.dev",
  "build": {
    "beforeDevCommand": "bun run scripts/tauri-dev-before.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Jean (Dev)",
        "width": 800,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ]
  }
}
